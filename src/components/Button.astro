---
/**
 * Bouton / lien d'action. Reprend les variantes de boutons des maquettes.
 * Rend un <a> par défaut, ou un <button> pour les actions de formulaire.
 */
type Variant = "solid" | "gold-light" | "ghost" | "ghost-light";

interface Props {
  href?: string;
  variant?: Variant;
  sm?: boolean;
  type?: "button" | "submit" | "reset";
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  variant = "solid",
  sm = false,
  type = "button",
  class: className,
  ...rest
} = Astro.props;

const variantClass: Record<Variant, string> = {
  solid: "",
  "gold-light": "btn--gold-light",
  ghost: "btn--ghost",
  "ghost-light": "btn--ghost-light",
};

const classes = ["btn", variantClass[variant], sm ? "btn--sm" : "", className]
  .filter(Boolean)
  .join(" ");
---

{
  href ? (
    <a class={classes} href={href} {...rest}>
      <slot />
    </a>
  ) : (
    <button class={classes} type={type} {...rest}>
      <slot />
    </button>
  )
}
