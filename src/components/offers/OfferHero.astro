---
import { Image } from "astro:assets";
import Button from "../Button.astro";
import { resolveVisual } from "../../data/images";

type Variant = "solid" | "gold-light" | "ghost" | "ghost-light";

interface Props {
  place: string;
  title: string[];
  lead: string;
  image: string;
  imageAlt?: string;
  placeColor?: "or" | "dim";
  actions?: { label: string; href: string; variant?: Variant }[];
}

const {
  place,
  title,
  lead,
  image,
  imageAlt,
  placeColor = "or",
  actions = [],
} = Astro.props;
const visual = resolveVisual(image);
const placeStyle =
  placeColor === "or" ? "color:var(--or);" : "color:var(--creme-dim);";
---

<header class="phero">
  <div class="phero__bg">
    <Image
      src={visual.src}
      alt={imageAlt ?? visual.alt}
      widths={[768, 1280, 2000]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
  </div>
  <div class="phero__in wrap">
    <p class="place" style={placeStyle}>{place}</p>
    <h1 class="display-xl">
      {
        title.map((line, i) => (
          <Fragment>
            {i > 0 && <br />}
            {line}
          </Fragment>
        ))
      }
    </h1>
    <p class="lead">{lead}</p>
    {
      actions.length > 0 && (
        <div class="cta-row">
          {actions.map((a) => (
            <Button href={a.href} variant={a.variant ?? "gold-light"}>
              {a.label}
            </Button>
          ))}
        </div>
      )
    }
  </div>
</header>

<style>
  .phero {
    position: relative;
    min-height: 64vh;
    display: flex;
    align-items: flex-end;
    color: var(--creme);
    background: var(--noir);
    overflow: hidden;
  }
  .phero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .phero__bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .phero__bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(8, 7, 5, 0.5),
      rgba(8, 7, 5, 0.25) 38%,
      rgba(8, 7, 5, 0.9)
    );
  }
  .phero__in {
    position: relative;
    z-index: 2;
    padding: 130px 0 56px;
    max-width: 780px;
  }
  .phero .place {
    font-family: var(--serif);
    text-transform: uppercase;
    letter-spacing: 0.42em;
    font-size: 11px;
  }
  .phero h1 {
    color: var(--creme);
    margin: 16px 0 18px;
  }
  .phero .lead {
    color: var(--creme-dim);
    font-size: 20px;
    max-width: 54ch;
    margin: 0 0 28px;
  }
  .phero .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }
</style>
