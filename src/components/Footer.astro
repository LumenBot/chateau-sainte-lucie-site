---
/**
 * Pied de page (registre nuit) : marque, liens du lieu, contact rapide,
 * plaquette (lead magnet) et bas de page légal.
 */
import { site, mainNav, legalNav, plaquette, ctaLabels } from "../data/site";
import { withBase } from "../utils/url";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap">
    <div class="foot-grid">
      <div class="foot-brand">
        <div class="bn">{site.name}</div>
        <div class="bs">{site.baseline}</div>
        <p>{site.tagline}</p>
      </div>

      <nav class="foot-col" aria-label="Le lieu">
        <h4>Le lieu</h4>
        {mainNav.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
      </nav>

      <div class="foot-col">
        <h4>Contact</h4>
        <a href={withBase("/contact")}>{ctaLabels.proposition}</a>
        <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
        <a href={site.contact.phoneHref}>{site.contact.phoneDisplay}</a>
        <p class="muted">Localisation exacte communiquée aux clients confirmés.</p>
      </div>

      <div class="foot-col">
        <h4>{plaquette.title}</h4>
        <p>{plaquette.text}</p>
        <a class="btn btn--ghost-light btn--sm" href={withBase(plaquette.href)} style="margin-top:6px;">
          {plaquette.cta}
        </a>
      </div>
    </div>

    <div class="foot-bottom">
      <span>© {year} {site.name} — Tous droits réservés.</span>
      <span class="legal">
        {legalNav.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
      </span>
    </div>
  </div>
</footer>
