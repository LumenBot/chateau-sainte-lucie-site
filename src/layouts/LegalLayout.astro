---
/**
 * Gabarit des pages légales (parchemin, en-tête clair sticky).
 * Le contenu est passé en slot et stylé via la classe globale `.prose`.
 */
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  seoTitle: string;
  description: string;
  updated: string;
}
const { title, seoTitle, description, updated } = Astro.props;
---

<BaseLayout
  title={seoTitle}
  description={description}
  solidHeader
  stickyCta={false}
>
  <header class="legal-hero">
    <div class="wrap narrow">
      <p class="eyebrow"><span class="ln"></span>Informations légales</p>
      <h1 class="display-l">{title}</h1>
      <p class="muted">Dernière mise à jour : {updated}</p>
    </div>
  </header>

  <section class="sec legal-body">
    <div class="wrap narrow">
      <div class="prose">
        <slot />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-hero {
    padding: clamp(48px, 8vw, 90px) 0 0;
  }
  .legal-hero h1 {
    margin: 16px 0 10px;
  }
  .legal-body {
    padding-top: 30px;
  }
</style>
