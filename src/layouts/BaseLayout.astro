---
/**
 * Gabarit de base : coquille HTML, <head> SEO, lien d'évitement, en-tête,
 * contenu, pied de page et CTA mobile persistant (optionnel).
 */
import "../styles/global.css";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site";

interface StickyCta {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  image?: string;
  ogType?: string;
  noindex?: boolean;
  solidHeader?: boolean;
  /** CTA mobile persistant ; passer `false` pour le masquer. */
  stickyCta?: StickyCta | false;
}

const {
  title,
  description,
  image,
  ogType,
  noindex,
  solidHeader = false,
  stickyCta = { label: "Demander une proposition", href: "/contact" },
} = Astro.props;
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      ogType={ogType}
      noindex={noindex}
    />
  </head>
  <body>
    <a class="skip-link" href="#contenu">Aller au contenu</a>
    <Header solid={solidHeader} />
    <main id="contenu">
      <slot />
    </main>
    <Footer />
    {
      stickyCta && (
        <div class="sticky-cta">
          <a class="btn btn--gold-light" href={stickyCta.href}>
            {stickyCta.label}
          </a>
        </div>
      )
    }
  </body>
</html>
