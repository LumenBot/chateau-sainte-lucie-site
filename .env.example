# =====================================================================
# Château de Sainte-Lucie — variables d'environnement (EXEMPLE)
# Copier ce fichier en `.env` et compléter. NE JAMAIS committer `.env`.
# =====================================================================

# URL canonique du site (utilisée pour le SEO, le sitemap et les OpenGraph).
# En production, renseigner le domaine définitif.
SITE_URL="https://chateau-saintelucie.fr"

# ---------------------------------------------------------------------
# Formulaire de contact
# ---------------------------------------------------------------------
# Solution par défaut : Netlify Forms (aucune clé requise — la détection
# se fait à la compilation sur Netlify). Rien à renseigner ici.
#
# Alternative : Web3Forms (si déploiement hors Netlify, ex. Cloudflare
# Pages). Créer une clé gratuite sur https://web3forms.com puis la coller
# ci-dessous. La clé est « publique » (côté client) mais reste hors dépôt.
PUBLIC_WEB3FORMS_KEY=""

# ---------------------------------------------------------------------
# Analytics (optionnel, décision marketing)
# ---------------------------------------------------------------------
# Plausible (respect de la vie privée, sans cookie). Renseigner le domaine
# déclaré dans Plausible pour activer le script.
PUBLIC_PLAUSIBLE_DOMAIN=""
